{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "commonjs",
    "moduleResolution": "node",
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "outDir": ".test-output",
    "rootDir": ".",
    "noEmit": false,
    "noEmitOnError": true,
    "incremental": false,
    "tsBuildInfoFile": ".test-output/tsconfig.test.tsbuildinfo"
  },
  "include": ["app/api/**/*.ts", "lib/**/*.ts", "tests/**/*.test.ts"]
}
